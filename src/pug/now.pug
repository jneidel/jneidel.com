extends base

block head
  title jneidel.com
  +links( "now" )
  style.
    .flex {
      display: flex;
    }
    .flex a {
      margin: 0 5px;
    }

block body
  h1 What I’m doing now
  i.flex
    p( style="margin: 0;" ) (This is a
    a( href="https://nownownow.com/about" ) now
    p( style="margin: 0;" ) page.)

  h2 Work
  p I started studying applied computer science at <a href="https://www.htw-berlin.de/">HTW Berlin</a> and moved to a flat near the university (Oberschöneweide).

  h2#media Media
  p This is a list of running manga and comics that I'm currently nollowing (updated weekly).
  p These are not recommendations per se, it's simply a list of what I'm reading.
  i P stands for paused; a series that is currently on a break.

  // Comic and manga data is passed in by webpack
  - const mangaTotal = manga.filter( x => !x.paused ).length
  h3#manga Manga (total: #{mangaTotal})
  .flex
    // p To download use:
    // a( href="https://github.com/jneidel/mangareader-dl" ) mangareader-dl
  table
    tr
      td name
      td latest chapter
      // td download command
    for i in manga
      tr
        td
          a( href=i.info )= i.readableName
        - const chapter = `${i.chapter}${i.paused ? " P" : ""}`
        td= chapter
        // td
          code= i.get

  - const comicsTotal = comics.filter( x => !x.paused ).length
  - comics = comics.filter( x => !x.paused )
  h3#comics Comics (total #{comicsTotal})
  .flex
  table
    tr
      td name
      td latest issue
    for i in comics
      tr
        td
          a( href=i.info )= i.name
        - const issue = `${i.issue}${i.paused ? " P" : ""}`
        td= issue

  hr
  .last-edit
    b( style="margin-bottom: 0;" ) Last Edit:
    p#lastEdit=lastEdit
    // Replaced with 'new Date()' on each webpack run
